local gameID = game.PlaceId
local TweenService = game:GetService("TweenService")
local TeleportService = game:GetService("TeleportService")
local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

local SupportedGames = {
    {id = 189707, name = "Natural Disaster Survival"},
    {id = 123974602339071, name = "Just A Baseplate"},
    {id = 88308889239232, name = "Green Baseplate"},
    {id = 102590772714636, name = "My Baseplate"},
}

local function ShowLoading()
    if CoreGui:FindFirstChild("MinhZLoading") then CoreGui.MinhZLoading:Destroy() end

    local ScreenGui = Instance.new("ScreenGui", CoreGui)
    ScreenGui.Name = "MinhZLoading"

    local MainFrame = Instance.new("Frame", ScreenGui)
    MainFrame.BackgroundColor3 = Color3.fromRGB(20, 18, 30)
    MainFrame.BackgroundTransparency = 0.1
    MainFrame.Position = UDim2.new(0.5, -180, 0.5, -85)
    MainFrame.Size = UDim2.new(0, 360, 0, 170)
    local MainCorner = Instance.new("UICorner", MainFrame)
    MainCorner.CornerRadius = UDim.new(0, 15)

    local Gradient = Instance.new("UIGradient", MainFrame)
    Gradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(30, 25, 45)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(20, 18, 30))
    }
    Gradient.Rotation = 45

    local CloseBtn = Instance.new("TextButton", MainFrame)
    CloseBtn.Size = UDim2.new(0, 30, 0, 30)
    CloseBtn.Position = UDim2.new(1, -35, 0, 5)
    CloseBtn.Text = "X"
    CloseBtn.Font = Enum.Font.GothamBold
    CloseBtn.TextSize = 18
    CloseBtn.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
    CloseBtn.TextColor3 = Color3.new(1, 1, 1)
    CloseBtn.BorderSizePixel = 0
    Instance.new("UICorner", CloseBtn).CornerRadius = UDim.new(0, 15)
    CloseBtn.MouseButton1Click:Connect(function()
        ScreenGui:Destroy()
    end)

    local Title = Instance.new("TextLabel", MainFrame)
    Title.BackgroundTransparency = 1
    Title.Size = UDim2.new(1, -40, 0, 40)
    Title.Position = UDim2.new(0, 20, 0, 0)
    Title.Font = Enum.Font.GothamBold
    Title.Text = "⚡ MinhZ Hub"
    Title.TextColor3 = Color3.fromRGB(200, 80, 180)
    Title.TextSize = 24
    Title.TextXAlignment = Enum.TextXAlignment.Left

    local LogLabel = Instance.new("TextLabel", MainFrame)
    LogLabel.BackgroundTransparency = 1
    LogLabel.Position = UDim2.new(0, 0, 0.35, 0)
    LogLabel.Size = UDim2.new(1, 0, 0, 20)
    LogLabel.Font = Enum.Font.Gotham
    LogLabel.Text = "Starting..."
    LogLabel.TextColor3 = Color3.new(1, 1, 1)
    LogLabel.TextSize = 13

    local PercentageLabel = Instance.new("TextLabel", MainFrame)
    PercentageLabel.BackgroundTransparency = 1
    PercentageLabel.Position = UDim2.new(0, 0, 0.5, 0)
    PercentageLabel.Size = UDim2.new(1, 0, 0, 20)
    PercentageLabel.Font = Enum.Font.GothamBold
    PercentageLabel.Text = "0%"
    PercentageLabel.TextColor3 = Color3.fromRGB(200, 80, 180)
    PercentageLabel.TextSize = 16

    local BarBack = Instance.new("Frame", MainFrame)
    BarBack.BackgroundColor3 = Color3.fromRGB(10, 10, 15)
    BarBack.BackgroundTransparency = 0.5
    BarBack.Position = UDim2.new(0.08, 0, 0.7, 0)
    BarBack.Size = UDim2.new(0.84, 0, 0, 8)
    BarBack.BorderSizePixel = 0
    Instance.new("UICorner", BarBack).CornerRadius = UDim.new(0, 4)

    local BarFill = Instance.new("Frame", BarBack)
    BarFill.BackgroundColor3 = Color3.fromRGB(200, 80, 180)
    BarFill.Size = UDim2.new(0, 0, 1, 0)
    BarFill.BorderSizePixel = 0
    Instance.new("UICorner", BarFill).CornerRadius = UDim.new(0, 4)

    local BarGradient = Instance.new("UIGradient", BarFill)
    BarGradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(200, 80, 180)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(150, 100, 255))
    }

    local dragging, dragStart, startPos
    Title.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(
                startPos.X.Scale, 
                startPos.X.Offset + delta.X, 
                startPos.Y.Scale, 
                startPos.Y.Offset + delta.Y
            )
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    local progress = 0
    local function UpdateUI(targetPercent, text, waitTime)
        LogLabel.Text = text
        if waitTime then task.wait(waitTime) end
        
        local startProgress = progress
        local steps = (targetPercent - startProgress) * 2
        local increment = (targetPercent - startProgress) / steps
        
        for i = 1, steps do
            progress = startProgress + (increment * i)
            if progress > targetPercent then progress = targetPercent end
            PercentageLabel.Text = math.floor(progress) .. "%"
            
            BarFill.Size = UDim2.new(progress/100, 0, 1, 0)
            task.wait(0.015)
        end
        
        progress = targetPercent
        PercentageLabel.Text = progress .. "%"
        BarFill.Size = UDim2.new(progress/100, 0, 1, 0)
    end

    UpdateUI(22, "Wait For Loading..")
    UpdateUI(46, "Check For New Update...")
    UpdateUI(78, "Check Game...", 2)

    local found = false
    for _, g in pairs(SupportedGames) do 
        if g.id == gameID then 
            found = g 
            break 
        end 
    end

    if found then
        UpdateUI(98, "Game Found!")
        UpdateUI(100, "Enjoy!!")
        task.wait(0.5)
        ScreenGui:Destroy()
        
        if gameID == 189707 then
            loadstring(game:HttpGet("https://raw.githubusercontent.com/Minh1234ngudot/MinhZ-Hub/refs/heads/main/MinhZ-Natural-Disaster"))()
        elseif gameID == 123974602339071 then
            loadstring(game:HttpGet("https://raw.githubusercontent.com/Minh1234ngudot/MinhZ-Hub/refs/heads/main/MinhZ-Just-A-Baseplate"))()
        elseif gameID == 88308889239232 then
            loadstring(game:HttpGet("https://raw.githubusercontent.com/Minh1234ngudot/MinhZ-Hub/refs/heads/main/MinhZ-Just-A-Baseplate"))()
        elseif gameID == 102590772714636 then
            loadstring(game:HttpGet("https://raw.githubusercontent.com/Minh1234ngudot/MinhZ-Hub/refs/heads/main/MinhZ-Just-A-Baseplate"))()
        end
    else
        LogLabel.Text = "⚠️ Your Game Is Not Supported"
        LogLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        PercentageLabel.Text = "FAILED"
        PercentageLabel.TextColor3 = Color3.fromRGB(255, 100, 100)

        local BtnFrame = Instance.new("Frame", MainFrame)
        BtnFrame.Size = UDim2.new(0.9, 0, 0, 32)
        BtnFrame.Position = UDim2.new(0.05, 0, 0.78, 0)
        BtnFrame.BackgroundTransparency = 1

        local ListBtn = Instance.new("TextButton", BtnFrame)
        ListBtn.Size = UDim2.new(0.48, 0, 1, 0)
        ListBtn.Position = UDim2.new(0, 0, 0, 0)
        ListBtn.Text = "📋 View Games"
        ListBtn.Font = Enum.Font.GothamBold
        ListBtn.BackgroundColor3 = Color3.fromRGB(200, 80, 180)
        ListBtn.TextColor3 = Color3.new(1, 1, 1)
        ListBtn.TextSize = 11
        ListBtn.BorderSizePixel = 0
        Instance.new("UICorner", ListBtn).CornerRadius = UDim.new(0, 6)

        local DiscordBtn = Instance.new("TextButton", BtnFrame)
        DiscordBtn.Size = UDim2.new(0.48, 0, 1, 0)
        DiscordBtn.Position = UDim2.new(0.52, 0, 0, 0)
        DiscordBtn.Text = "💬 Discord"
        DiscordBtn.Font = Enum.Font.GothamBold
        DiscordBtn.BackgroundColor3 = Color3.fromRGB(88, 101, 242)
        DiscordBtn.TextColor3 = Color3.new(1, 1, 1)
        DiscordBtn.TextSize = 11
        DiscordBtn.BorderSizePixel = 0
        Instance.new("UICorner", DiscordBtn).CornerRadius = UDim.new(0, 6)

        DiscordBtn.MouseButton1Click:Connect(function()
            setclipboard("https://discord.gg/YOUR_DISCORD_INVITE")
            DiscordBtn.Text = "✅ Copied!"
            task.wait(1.5)
            DiscordBtn.Text = "💬 Discord"
        end)

        ListBtn.MouseButton1Click:Connect(function()
            ListBtn.Visible = false
            DiscordBtn.Visible = false
            LogLabel.Visible = false
            PercentageLabel.Visible = false
            BarBack.Visible = false
            
            Title.Text = "📋 Supported Games"
            Title.Position = UDim2.new(0, 20, 0, 0)
            Title.TextXAlignment = Enum.TextXAlignment.Left
            
            local tween = TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {
                Size = UDim2.new(0, 380, 0, 320),
                Position = UDim2.new(0.5, -190, 0.5, -160)
            })
            tween:Play()
            tween.Completed:Wait()

            local Scroll = Instance.new("ScrollingFrame", MainFrame)
            Scroll.Name = "GameList"
            Scroll.Size = UDim2.new(0.92, 0, 0.65, 0)
            Scroll.Position = UDim2.new(0.04, 0, 0.18, 0)
            Scroll.BackgroundTransparency = 1
            Scroll.BorderSizePixel = 0
            Scroll.ScrollBarThickness = 4
            Scroll.ScrollBarImageColor3 = Color3.fromRGB(200, 80, 180)
            Scroll.CanvasSize = UDim2.new(0, 0, 0, #SupportedGames * 52)

            for i, g in pairs(SupportedGames) do
                local GFrame = Instance.new("Frame", Scroll)
                GFrame.Size = UDim2.new(0.96, 0, 0, 46)
                GFrame.Position = UDim2.new(0.02, 0, 0, (i-1)*52)
                GFrame.BackgroundColor3 = Color3.fromRGB(38, 30, 50)
                GFrame.BorderSizePixel = 0
                Instance.new("UICorner", GFrame).CornerRadius = UDim.new(0, 8)

                local GName = Instance.new("TextLabel", GFrame)
                GName.Text = g.name
                GName.Size = UDim2.new(0.58, 0, 1, 0)
                GName.TextColor3 = Color3.new(1, 1, 1)
                GName.Font = Enum.Font.GothamBold
                GName.TextSize = 12
                GName.BackgroundTransparency = 1
                GName.TextXAlignment = Enum.TextXAlignment.Left
                GName.Position = UDim2.new(0.05, 0, 0, 0)

                local Join = Instance.new("TextButton", GFrame)
                Join.Text = "JOIN"
                Join.Size = UDim2.new(0.3, 0, 0.65, 0)
                Join.Position = UDim2.new(0.66, 0, 0.175, 0)
                Join.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
                Join.Font = Enum.Font.GothamBold
                Join.TextColor3 = Color3.new(1, 1, 1)
                Join.TextSize = 11
                Join.BorderSizePixel = 0
                Instance.new("UICorner", Join).CornerRadius = UDim.new(0, 6)

                Join.MouseEnter:Connect(function()
                    TweenService:Create(Join, TweenInfo.new(0.2), {
                        BackgroundColor3 = Color3.fromRGB(0, 230, 120)
                    }):Play()
                end)

                Join.MouseLeave:Connect(function()
                    TweenService:Create(Join, TweenInfo.new(0.2), {
                        BackgroundColor3 = Color3.fromRGB(0, 200, 100)
                    }):Play()
                end)

                Join.MouseButton1Click:Connect(function()
                    Join.Text = "Joining..."
                    Join.BackgroundColor3 = Color3.fromRGB(255, 150, 0)
                    TeleportService:Teleport(g.id, Players.LocalPlayer)
                end)
            end

            local BackBtn = Instance.new("TextButton", MainFrame)
            BackBtn.Name = "BackBtn"
            BackBtn.Size = UDim2.new(0.4, 0, 0, 32)
            BackBtn.Position = UDim2.new(0.3, 0, 0.88, 0)
            BackBtn.Text = "← Back"
            BackBtn.Font = Enum.Font.GothamBold
            BackBtn.BackgroundColor3 = Color3.fromRGB(60, 50, 70)
            BackBtn.TextColor3 = Color3.new(1, 1, 1)
            BackBtn.TextSize = 12
            BackBtn.BorderSizePixel = 0
            Instance.new("UICorner", BackBtn).CornerRadius = UDim.new(0, 6)

            BackBtn.MouseButton1Click:Connect(function()
                if Scroll then Scroll:Destroy() end
                if BackBtn then BackBtn:Destroy() end
                
                Title.Text = "⚡ MinhZ Hub Loader ⚡"
                Title.Position = UDim2.new(0, 20, 0, 0)
                Title.TextXAlignment = Enum.TextXAlignment.Left
                
                local tween = TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {
                    Size = UDim2.new(0, 360, 0, 170),
                    Position = UDim2.new(0.5, -180, 0.5, -85)
                })
                tween:Play()
                tween.Completed:Wait()
                
                LogLabel.Visible = true
                PercentageLabel.Visible = true
                BarBack.Visible = true
                ListBtn.Visible = true
                DiscordBtn.Visible = true
            end)
        end)
    end
end

ShowLoading()
